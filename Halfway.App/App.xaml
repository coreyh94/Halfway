<Application
    x:Class="Halfway.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AppBackgroundColor">#FFF4F5F7</Color><Color x:Key="TopBarBackgroundColor">#FFFFFFFF</Color><Color x:Key="SidebarBackgroundColor">#FFF8F9FB</Color><Color x:Key="MainBackgroundColor">#FFEFF1F4</Color><Color x:Key="SubAgentBackgroundColor">#FFF8F9FB</Color><Color x:Key="TerminalBackgroundColor">#FFFFFFFF</Color><Color x:Key="TabBackgroundColor">#FFF1F3F6</Color><Color x:Key="BorderColor">#FFD5D9E0</Color><Color x:Key="PrimaryTextColor">#FF171A20</Color><Color x:Key="SecondaryTextColor">#FF4F5968</Color><Color x:Key="MutedTextColor">#FF687386</Color><Color x:Key="SidebarTextColor">#FF3E4652</Color><Color x:Key="SelectedBackgroundColor">#FFDDE5F2</Color><Color x:Key="TransparentColor">#00000000</Color><Color x:Key="RunningColor">#FF16784B</Color><Color x:Key="WaitingColor">#FF8A5B00</Color><Color x:Key="CompletedColor">#FF4F55B5</Color><Color x:Key="ErrorColor">#FFB4232B</Color><Color x:Key="SearchMatchColor">#668A93A3</Color><Color x:Key="SearchCurrentColor">#FFF0C35A</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="AppBackgroundColor">#FF101114</Color><Color x:Key="TopBarBackgroundColor">#FF17191E</Color><Color x:Key="SidebarBackgroundColor">#FF15171B</Color><Color x:Key="MainBackgroundColor">#FF0F1013</Color><Color x:Key="SubAgentBackgroundColor">#FF15171B</Color><Color x:Key="TerminalBackgroundColor">#FF0A0B0D</Color><Color x:Key="TabBackgroundColor">#FF111318</Color><Color x:Key="BorderColor">#FF2C3039</Color><Color x:Key="PrimaryTextColor">#FFF3F4F6</Color><Color x:Key="SecondaryTextColor">#FFC9D1DC</Color><Color x:Key="MutedTextColor">#FF8D96A5</Color><Color x:Key="SidebarTextColor">#FFB9C0CB</Color><Color x:Key="SelectedBackgroundColor">#FF252A35</Color><Color x:Key="TransparentColor">#00000000</Color><Color x:Key="RunningColor">#FF7DD3A8</Color><Color x:Key="WaitingColor">#FFF1C77A</Color><Color x:Key="CompletedColor">#FF9DA7FF</Color><Color x:Key="ErrorColor">#FFF18A8A</Color><Color x:Key="SearchMatchColor">#8C5A606E</Color><Color x:Key="SearchCurrentColor">#FFF1C77A</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource AppBackgroundColor}"/><SolidColorBrush x:Key="TopBarBackgroundBrush" Color="{ThemeResource TopBarBackgroundColor}"/><SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{ThemeResource SidebarBackgroundColor}"/><SolidColorBrush x:Key="MainBackgroundBrush" Color="{ThemeResource MainBackgroundColor}"/><SolidColorBrush x:Key="SubAgentBackgroundBrush" Color="{ThemeResource SubAgentBackgroundColor}"/><SolidColorBrush x:Key="TerminalBackgroundBrush" Color="{ThemeResource TerminalBackgroundColor}"/><SolidColorBrush x:Key="TabBackgroundBrush" Color="{ThemeResource TabBackgroundColor}"/><SolidColorBrush x:Key="BorderBrush" Color="{ThemeResource BorderColor}"/><SolidColorBrush x:Key="PrimaryTextBrush" Color="{ThemeResource PrimaryTextColor}"/><SolidColorBrush x:Key="SecondaryTextBrush" Color="{ThemeResource SecondaryTextColor}"/><SolidColorBrush x:Key="MutedTextBrush" Color="{ThemeResource MutedTextColor}"/><SolidColorBrush x:Key="SidebarTextBrush" Color="{ThemeResource SidebarTextColor}"/><SolidColorBrush x:Key="SelectedBackgroundBrush" Color="{ThemeResource SelectedBackgroundColor}"/><SolidColorBrush x:Key="TransparentBrush" Color="{ThemeResource TransparentColor}"/><SolidColorBrush x:Key="RunningBrush" Color="{ThemeResource RunningColor}"/><SolidColorBrush x:Key="WaitingBrush" Color="{ThemeResource WaitingColor}"/><SolidColorBrush x:Key="CompletedBrush" Color="{ThemeResource CompletedColor}"/><SolidColorBrush x:Key="ErrorBrush" Color="{ThemeResource ErrorColor}"/><SolidColorBrush x:Key="SearchMatchBrush" Color="{ThemeResource SearchMatchColor}"/><SolidColorBrush x:Key="SearchCurrentBrush" Color="{ThemeResource SearchCurrentColor}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
