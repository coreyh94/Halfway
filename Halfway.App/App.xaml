<Application
    x:Class="Halfway.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- ============================================================ -->
            <!-- Semantic colours: one role vocabulary, two theme palettes.    -->
            <!-- ============================================================ -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AppBackgroundColor">#FFF3F4F7</Color>
                    <Color x:Key="TopBarBackgroundColor">#FFFBFBFD</Color>
                    <Color x:Key="SidebarBackgroundColor">#FFF7F8FA</Color>
                    <Color x:Key="MainBackgroundColor">#FFEEF0F3</Color>
                    <Color x:Key="SubAgentBackgroundColor">#FFF7F8FA</Color>
                    <Color x:Key="TerminalBackgroundColor">#FFFFFFFF</Color>
                    <Color x:Key="TabBackgroundColor">#FFEEF0F3</Color>
                    <Color x:Key="BorderColor">#FFDCE0E7</Color>
                    <Color x:Key="BorderStrongColor">#FFBFC6D1</Color>
                    <Color x:Key="PrimaryTextColor">#FF171A20</Color>
                    <Color x:Key="SecondaryTextColor">#FF4C5566</Color>
                    <Color x:Key="MutedTextColor">#FF6C7789</Color>
                    <Color x:Key="SidebarTextColor">#FF3B4452</Color>
                    <Color x:Key="SelectedBackgroundColor">#FFDEE6F4</Color>
                    <Color x:Key="TransparentColor">#00000000</Color>
                    <Color x:Key="ControlFillColor">#FFFFFFFF</Color>
                    <Color x:Key="ControlFillHoverColor">#FFEFF1F5</Color>
                    <Color x:Key="ControlFillPressedColor">#FFE4E8EE</Color>
                    <Color x:Key="SubtleHoverColor">#0F000000</Color>
                    <Color x:Key="SubtlePressedColor">#1A000000</Color>
                    <Color x:Key="ChipBackgroundColor">#FFFFFFFF</Color>
                    <Color x:Key="AccentColor">#FF4A52C0</Color>
                    <Color x:Key="AccentHoverColor">#FF545CCB</Color>
                    <Color x:Key="AccentPressedColor">#FF3F47AC</Color>
                    <Color x:Key="AccentTextColor">#FFFFFFFF</Color>
                    <Color x:Key="SplitterColor">#FFE2E5EA</Color>
                    <Color x:Key="SplitterHoverColor">#FF4A52C0</Color>
                    <Color x:Key="RunningColor">#FF16784B</Color>
                    <Color x:Key="WaitingColor">#FF8A5B00</Color>
                    <Color x:Key="CompletedColor">#FF4F55B5</Color>
                    <Color x:Key="ErrorColor">#FFB4232B</Color>
                    <Color x:Key="SearchMatchColor">#668A93A3</Color>
                    <Color x:Key="SearchCurrentColor">#FFF0C35A</Color>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="AppBackgroundColor">#FF101114</Color>
                    <Color x:Key="TopBarBackgroundColor">#FF16181D</Color>
                    <Color x:Key="SidebarBackgroundColor">#FF15171B</Color>
                    <Color x:Key="MainBackgroundColor">#FF0F1013</Color>
                    <Color x:Key="SubAgentBackgroundColor">#FF15171B</Color>
                    <Color x:Key="TerminalBackgroundColor">#FF0A0B0D</Color>
                    <Color x:Key="TabBackgroundColor">#FF111318</Color>
                    <Color x:Key="BorderColor">#FF2A2E37</Color>
                    <Color x:Key="BorderStrongColor">#FF3B424E</Color>
                    <Color x:Key="PrimaryTextColor">#FFF3F4F6</Color>
                    <Color x:Key="SecondaryTextColor">#FFC9D1DC</Color>
                    <Color x:Key="MutedTextColor">#FF8D96A5</Color>
                    <Color x:Key="SidebarTextColor">#FFB9C0CB</Color>
                    <Color x:Key="SelectedBackgroundColor">#FF262C38</Color>
                    <Color x:Key="TransparentColor">#00000000</Color>
                    <Color x:Key="ControlFillColor">#FF1C1F27</Color>
                    <Color x:Key="ControlFillHoverColor">#FF262A33</Color>
                    <Color x:Key="ControlFillPressedColor">#FF16181E</Color>
                    <Color x:Key="SubtleHoverColor">#16FFFFFF</Color>
                    <Color x:Key="SubtlePressedColor">#24FFFFFF</Color>
                    <Color x:Key="ChipBackgroundColor">#FF191C23</Color>
                    <Color x:Key="AccentColor">#FF6D79E6</Color>
                    <Color x:Key="AccentHoverColor">#FF7B86EE</Color>
                    <Color x:Key="AccentPressedColor">#FF5C68D4</Color>
                    <Color x:Key="AccentTextColor">#FFFBFCFF</Color>
                    <Color x:Key="SplitterColor">#FF20242C</Color>
                    <Color x:Key="SplitterHoverColor">#FF6D79E6</Color>
                    <Color x:Key="RunningColor">#FF7DD3A8</Color>
                    <Color x:Key="WaitingColor">#FFF1C77A</Color>
                    <Color x:Key="CompletedColor">#FF9DA7FF</Color>
                    <Color x:Key="ErrorColor">#FFF18A8A</Color>
                    <Color x:Key="SearchMatchColor">#8C5A606E</Color>
                    <Color x:Key="SearchCurrentColor">#FFF1C77A</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ============================================================ -->
            <!-- Semantic brushes (colour flips with the theme dictionary).    -->
            <!-- ============================================================ -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{ThemeResource AppBackgroundColor}"/>
            <SolidColorBrush x:Key="TopBarBackgroundBrush" Color="{ThemeResource TopBarBackgroundColor}"/>
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{ThemeResource SidebarBackgroundColor}"/>
            <SolidColorBrush x:Key="MainBackgroundBrush" Color="{ThemeResource MainBackgroundColor}"/>
            <SolidColorBrush x:Key="SubAgentBackgroundBrush" Color="{ThemeResource SubAgentBackgroundColor}"/>
            <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="{ThemeResource TerminalBackgroundColor}"/>
            <SolidColorBrush x:Key="TabBackgroundBrush" Color="{ThemeResource TabBackgroundColor}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{ThemeResource BorderColor}"/>
            <SolidColorBrush x:Key="BorderStrongBrush" Color="{ThemeResource BorderStrongColor}"/>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="{ThemeResource PrimaryTextColor}"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="{ThemeResource SecondaryTextColor}"/>
            <SolidColorBrush x:Key="MutedTextBrush" Color="{ThemeResource MutedTextColor}"/>
            <SolidColorBrush x:Key="SidebarTextBrush" Color="{ThemeResource SidebarTextColor}"/>
            <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="{ThemeResource SelectedBackgroundColor}"/>
            <SolidColorBrush x:Key="TransparentBrush" Color="{ThemeResource TransparentColor}"/>
            <SolidColorBrush x:Key="ControlFillBrush" Color="{ThemeResource ControlFillColor}"/>
            <SolidColorBrush x:Key="ControlFillHoverBrush" Color="{ThemeResource ControlFillHoverColor}"/>
            <SolidColorBrush x:Key="ControlFillPressedBrush" Color="{ThemeResource ControlFillPressedColor}"/>
            <SolidColorBrush x:Key="SubtleHoverBrush" Color="{ThemeResource SubtleHoverColor}"/>
            <SolidColorBrush x:Key="SubtlePressedBrush" Color="{ThemeResource SubtlePressedColor}"/>
            <SolidColorBrush x:Key="ChipBackgroundBrush" Color="{ThemeResource ChipBackgroundColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource AccentColor}"/>
            <SolidColorBrush x:Key="AccentHoverBrush" Color="{ThemeResource AccentHoverColor}"/>
            <SolidColorBrush x:Key="AccentPressedBrush" Color="{ThemeResource AccentPressedColor}"/>
            <SolidColorBrush x:Key="AccentTextBrush" Color="{ThemeResource AccentTextColor}"/>
            <SolidColorBrush x:Key="SplitterBrush" Color="{ThemeResource SplitterColor}"/>
            <SolidColorBrush x:Key="SplitterHoverBrush" Color="{ThemeResource SplitterHoverColor}"/>
            <SolidColorBrush x:Key="RunningBrush" Color="{ThemeResource RunningColor}"/>
            <SolidColorBrush x:Key="WaitingBrush" Color="{ThemeResource WaitingColor}"/>
            <SolidColorBrush x:Key="CompletedBrush" Color="{ThemeResource CompletedColor}"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="{ThemeResource ErrorColor}"/>
            <SolidColorBrush x:Key="SearchMatchBrush" Color="{ThemeResource SearchMatchColor}"/>
            <SolidColorBrush x:Key="SearchCurrentBrush" Color="{ThemeResource SearchCurrentColor}"/>

            <!-- ============================================================ -->
            <!-- Shared dimensions.                                            -->
            <!-- ============================================================ -->
            <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="SurfaceCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="ChipCornerRadius">11</CornerRadius>
            <x:Double x:Key="StatusDotSize">8</x:Double>

            <!-- ============================================================ -->
            <!-- Section caption (AGENT / SUB-AGENTS and panel titles).        -->
            <!-- ============================================================ -->
            <Style x:Key="SectionCaptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="CharacterSpacing" Value="80"/>
                <Setter Property="Foreground" Value="{ThemeResource MutedTextBrush}"/>
            </Style>

            <!-- ============================================================ -->
            <!-- Information-bar count chip and thin separator.                -->
            <!-- ============================================================ -->
            <Style x:Key="CountChipStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource ChipBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="{StaticResource ChipCornerRadius}"/>
                <Setter Property="Padding" Value="9,3,11,3"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="InfoSeparatorStyle" TargetType="Border">
                <Setter Property="Width" Value="1"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Background" Value="{ThemeResource BorderBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- ============================================================ -->
            <!-- Subtle / secondary button: toolbar and utility actions.       -->
            <!-- ============================================================ -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource ControlFillBrush}"/>
                <Setter Property="Foreground" Value="{ThemeResource SecondaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12,5,12,5"/>
                <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter x:Name="Content"
                                                  Padding="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillHoverBrush}"/>
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource BorderStrongBrush}"/>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource PrimaryTextBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillPressedBrush}"/>
                                                <Setter Target="Root.BorderBrush" Value="{ThemeResource BorderStrongBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Opacity" Value="0.45"/>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource MutedTextBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!-- Primary action button (accent). Used for Start / Restart.     -->
            <!-- ============================================================ -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{ThemeResource AccentTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="14,5,14,5"/>
                <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter x:Name="Content"
                                                  Padding="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AccentHoverBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource AccentPressedBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Root.Background" Value="{ThemeResource ControlFillBrush}"/>
                                                <Setter Target="Root.Opacity" Value="0.6"/>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource MutedTextBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!-- Sidebar row. Selection is carried by the templated Background  -->
            <!-- (set in code); a separate overlay carries hover/pressed so the -->
            <!-- selected fill always shows through.                           -->
            <!-- ============================================================ -->
            <Style x:Key="SidebarRowButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource TransparentBrush}"/>
                <Setter Property="Foreground" Value="{ThemeResource SidebarTextBrush}"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="10,8,10,8"/>
                <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="Root"
                                  Background="{TemplateBinding Background}"
                                  CornerRadius="{TemplateBinding CornerRadius}">
                                <Border x:Name="Hover"
                                        Background="{ThemeResource TransparentBrush}"
                                        CornerRadius="{TemplateBinding CornerRadius}"/>
                                <ContentPresenter x:Name="Content"
                                                  Padding="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalContentAlignment="Stretch"
                                                  VerticalContentAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Hover.Background" Value="{ThemeResource SubtleHoverBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Hover.Background" Value="{ThemeResource SubtlePressedBrush}"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Content.Opacity" Value="0.5"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!-- Panel splitter: a wide invisible grab area with a slim rule    -->
            <!-- that strengthens on hover for discoverability.                -->
            <!-- ============================================================ -->
            <Style x:Key="SplitterThumbStyle" TargetType="primitives:Thumb">
                <Setter Property="Background" Value="{ThemeResource TransparentBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="primitives:Thumb">
                            <Grid x:Name="Root" Background="{TemplateBinding Background}">
                                <Rectangle x:Name="Rule"
                                           Width="1"
                                           HorizontalAlignment="Center"
                                           Fill="{ThemeResource SplitterBrush}"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Rule.Fill" Value="{ThemeResource SplitterHoverBrush}"/>
                                                <Setter Target="Rule.Width" Value="2"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Rule.Fill" Value="{ThemeResource SplitterHoverBrush}"/>
                                                <Setter Target="Rule.Width" Value="2"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================ -->
            <!-- Monospace terminal input and the find-in-terminal box.        -->
            <!-- ============================================================ -->
            <Style x:Key="TerminalInputStyle" TargetType="TextBox">
                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
            </Style>

            <Style x:Key="SearchBoxStyle" TargetType="TextBox">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="MinHeight" Value="32"/>
                <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
            </Style>

            <!-- ============================================================ -->
            <!-- Compact workspace selector.                                   -->
            <!-- ============================================================ -->
            <Style x:Key="WorkspaceSelectorStyle" TargetType="ComboBox">
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CornerRadius" Value="{StaticResource ControlCornerRadius}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
