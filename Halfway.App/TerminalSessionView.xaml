<UserControl
    x:Class="Halfway.App.TerminalSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="Panel" Background="#0A0B0D" BorderBrush="#272C35" BorderThickness="1" CornerRadius="5" Padding="12" SizeChanged="Panel_SizeChanged">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock x:Name="TitleText" Foreground="#AAB2BF" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="DISCONNECTED" Foreground="#F1C77A" VerticalAlignment="Center"/>
                <Button x:Name="StartButton" Content="Start" Click="StartButton_Click"/>
                <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" IsEnabled="False"/>
                <Button x:Name="PowerShellButton" Content="PowerShell" Click="PowerShellButton_Click" Visibility="Collapsed"/>
                <Button x:Name="CodexButton" Content="Codex" Click="CodexButton_Click" Visibility="Collapsed"/>
                <Button x:Name="DemoAlertButton" Content="Inject demo alert" Click="DemoAlertButton_Click" Visibility="Collapsed"/>
            </StackPanel>
            <ScrollViewer x:Name="OutputScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock x:Name="OutputText" TextWrapping="NoWrap" FontFamily="Cascadia Mono, Consolas" FontSize="13" Foreground="#D5DAE2" IsTextSelectionEnabled="True"/>
            </ScrollViewer>
            <TextBox x:Name="InputText" Grid.Row="2" Margin="0,8,0,0" FontFamily="Cascadia Mono, Consolas" PlaceholderText="Type a command and press Enter" KeyDown="InputText_KeyDown" TextChanged="InputText_TextChanged"/>
        </Grid>
    </Border>
</UserControl>
