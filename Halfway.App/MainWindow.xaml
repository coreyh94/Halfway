<Window x:Class="Halfway.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
        xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
        Title="Halfway">
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Number1" Modifiers="Control" Invoked="FocusPrimary_Invoked"/>
            <KeyboardAccelerator Key="Number2" Modifiers="Control" Invoked="FocusSubAgent_Invoked"/>
            <KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="NextSubAgent_Invoked"/>
            <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="PreviousSubAgent_Invoked"/>
            <KeyboardAccelerator Key="Up" Modifiers="Menu" Invoked="PreviousSidebarSession_Invoked"/>
            <KeyboardAccelerator Key="Down" Modifiers="Menu" Invoked="NextSidebarSession_Invoked"/>
            <KeyboardAccelerator Key="N" Modifiers="Control,Shift" Invoked="AddSubAgent_Invoked"/>
            <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OpenTerminalSearch_Invoked"/>
            <KeyboardAccelerator Key="F3" Invoked="NextSearchMatch_Invoked"/>
            <KeyboardAccelerator Key="F3" Modifiers="Shift" Invoked="PreviousSearchMatch_Invoked"/>
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Information bar -->
        <Border Background="{ThemeResource TopBarBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Padding="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HALFWAY" FontSize="15" FontWeight="SemiBold" CharacterSpacing="60" Foreground="{ThemeResource PrimaryTextBrush}"/>
                    <TextBlock Text="Codex workspace" FontSize="11" Foreground="{ThemeResource MutedTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="14" Margin="28,0,0,0">
                    <ComboBox x:Name="WorkspaceSelector" Style="{StaticResource WorkspaceSelectorStyle}" MinWidth="180" MaxWidth="320" PlaceholderText="Workspace" SelectionChanged="WorkspaceSelector_SelectionChanged"/>
                    <Border Style="{StaticResource InfoSeparatorStyle}"/>
                    <TextBlock x:Name="RepositoryText" FontSize="13" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource InfoSeparatorStyle}"/>
                    <TextBlock x:Name="BranchText" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource InfoSeparatorStyle}"/>
                    <TextBlock Text="MODEL —" FontSize="13" Foreground="{ThemeResource MutedTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <Border Style="{StaticResource CountChipStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{ThemeResource RunningBrush}"/>
                            <TextBlock x:Name="RunningCountText" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CountChipStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{ThemeResource WaitingBrush}"/>
                            <TextBlock x:Name="WaitingCountText" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CountChipStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{ThemeResource CompletedBrush}"/>
                            <TextBlock x:Name="CompletedCountText" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource InfoSeparatorStyle}" Margin="4,0"/>
                    <TextBlock x:Name="ConnectionText" FontSize="11" Foreground="{ThemeResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    <Button Content="Export diagnostics" Style="{StaticResource SubtleButtonStyle}" FontSize="12" Padding="12,4" Margin="4,0,0,0" Click="ExportDiagnostics_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Fixed three-region workspace -->
        <Grid x:Name="WorkspaceGrid" Grid.Row="1" SizeChanged="WorkspaceGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="236"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="PrimaryColumn" Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="SubAgentColumn" Width="420"/>
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource SidebarBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0" Padding="14,20">
                <ScrollViewer>
                    <StackPanel Spacing="8">
                        <TextBlock Text="AGENT" Style="{StaticResource SectionCaptionTextStyle}" Margin="8,0,0,4"/>
                        <StackPanel x:Name="PrimaryList" Spacing="4"/>
                        <Grid Margin="8,22,0,4">
                            <TextBlock Text="SUB-AGENTS" Style="{StaticResource SectionCaptionTextStyle}" VerticalAlignment="Center"/>
                            <Button Content="Add sub-agent" Style="{StaticResource SubtleButtonStyle}" FontSize="12" Padding="10,3" HorizontalAlignment="Right" Margin="0,0,2,0" Click="AddSubAgent_Click"/>
                        </Grid>
                        <StackPanel x:Name="SubAgentList" Spacing="4"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <primitives:Thumb Grid.Column="1" Style="{StaticResource SplitterThumbStyle}" IsTabStop="False" DragDelta="SidebarSplitter_DragDelta" DoubleTapped="SidebarSplitter_DoubleTapped"/>

            <Border Grid.Column="2" Background="{ThemeResource MainBackgroundBrush}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="4,0,0,14" Spacing="1">
                        <TextBlock Text="MAIN AGENT" Style="{StaticResource SectionCaptionTextStyle}"/>
                        <TextBlock x:Name="MainSessionTitle" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <Grid x:Name="PrimaryTerminalHost" Grid.Row="1"/>
                </Grid>
            </Border>

            <primitives:Thumb Grid.Column="3" Style="{StaticResource SplitterThumbStyle}" IsTabStop="False" DragDelta="SubAgentSplitter_DragDelta" DoubleTapped="SubAgentSplitter_DoubleTapped"/>

            <Border Grid.Column="4" Background="{ThemeResource SubAgentBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1,0,0,0" Padding="14,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SUB-AGENTS" Style="{StaticResource SectionCaptionTextStyle}" Margin="4,0,0,12"/>
                    <muxc:TabView x:Name="SubAgentTabs" Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="Equal" Background="{ThemeResource TabBackgroundBrush}" SelectionChanged="SubAgentTabs_SelectionChanged"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
