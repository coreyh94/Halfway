<Window
    x:Class="Halfway.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Halfway">
    <Grid Background="#101114">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#17191E" BorderBrush="#2C3039" BorderThickness="0,0,0,1">
            <Grid Padding="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HALFWAY" FontSize="15" FontWeight="SemiBold" Foreground="#F3F4F6" />
                    <TextBlock Text="Codex workspace" FontSize="11" Foreground="#8D96A5" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="20">
                    <TextBlock Text="Halfway" Foreground="#C9D1DC" />
                    <TextBlock Text="No repository" Foreground="#8D96A5" />
                    <TextBlock Text="main" Foreground="#8D96A5" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock x:Name="RunningCountText" Text="RUNNING 1" Foreground="#7DD3A8" FontSize="11" />
                    <TextBlock x:Name="WaitingCountText" Text="WAITING 1" Foreground="#F1C77A" FontSize="11" />
                    <TextBlock x:Name="CompletedCountText" Text="COMPLETE 1" Foreground="#9DA7FF" FontSize="11" />
                    <TextBlock Text="● CONNECTED" Foreground="#7DD3A8" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#15171B" BorderBrush="#2C3039" BorderThickness="0,0,1,0" Padding="14,22">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="AGENT" FontSize="11" FontWeight="SemiBold" Foreground="#7B8492" Margin="8,0,0,6" />
                        <Button x:Name="PlannerButton" Click="PlannerButton_Click" HorizontalContentAlignment="Left" Background="#252A35" Foreground="#F3F4F6" Padding="10,9">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="●" Foreground="#7DD3A8" />
                                <TextBlock Text="Planner" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ProjectManagerButton" Click="ProjectManagerButton_Click" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B9C0CB" Padding="10,9">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="◐" Foreground="#F1C77A" />
                                <TextBlock Text="Project Manager" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="SUB-AGENTS" FontSize="11" FontWeight="SemiBold" Foreground="#7B8492" Margin="8,28,0,6" />
                        <Button x:Name="RuntimeButton" Click="RuntimeButton_Click" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B9C0CB" Padding="10,9">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock x:Name="RuntimeButtonStatus" Text="○" Foreground="#F1C77A" />
                                <TextBlock Text="Runtime" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UiButton" Click="UiButton_Click" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B9C0CB" Padding="10,9">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="✓" Foreground="#9DA7FF" />
                                <TextBlock Text="UI" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="TestsButton" Click="TestsButton_Click" HorizontalContentAlignment="Left" Background="Transparent" Foreground="#B9C0CB" Padding="10,9">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="!" Foreground="#F18A8A" />
                                <TextBlock Text="Tests" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Phase 1 shell" FontSize="11" Foreground="#636B78" Margin="8,30,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Background="#0F1013" Padding="18,18,12,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,0,0,14">
                        <TextBlock x:Name="MainSessionTitle" Text="Planner" FontSize="16" FontWeight="SemiBold" Foreground="#F3F4F6" />
                        <TextBlock Text="PRIMARY SESSION" FontSize="11" Foreground="#7B8492" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border x:Name="TerminalPanel" Grid.Row="1" Background="#0A0B0D" BorderBrush="#272C35" BorderThickness="1" CornerRadius="5" SizeChanged="TerminalPanel_SizeChanged">
                        <Grid Padding="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                <Button Content="PowerShell" Click="PowerShellButton_Click" />
                                <Button Content="Codex" Click="CodexButton_Click" />
                                <Button x:Name="AlertButton" Content="Inject demo alert" Click="AlertButton_Click" />
                                <TextBlock x:Name="TerminalStatusText" Text="QUEUED" Foreground="#F1C77A" VerticalAlignment="Center" />
                            </StackPanel>
                            <ScrollViewer x:Name="TerminalScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TerminalOutputText" TextWrapping="NoWrap" FontFamily="Cascadia Mono, Consolas" FontSize="13" Foreground="#D5DAE2" IsTextSelectionEnabled="True" />
                            </ScrollViewer>
                            <TextBox x:Name="TerminalInputText" Grid.Row="2" Margin="0,8,0,0" FontFamily="Cascadia Mono, Consolas" PlaceholderText="Type a command and press Enter" KeyDown="TerminalInputText_KeyDown" TextChanged="TerminalInputText_TextChanged" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#15171B" BorderBrush="#2C3039" BorderThickness="1,0,0,0" Padding="14,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="SUB-AGENTS" FontSize="11" FontWeight="SemiBold" Foreground="#7B8492" Margin="4,0,0,12" />
                    <muxc:TabView x:Name="SubAgentTabs" Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="Equal" Background="#111318">
                        <muxc:TabViewItem x:Name="RuntimeTab" Header="Runtime ○">
                            <Border x:Name="RuntimePanel" Background="#0A0B0D" BorderBrush="#272C35" BorderThickness="1" CornerRadius="5" Padding="12" SizeChanged="RuntimePanel_SizeChanged">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                        <TextBlock Text="PowerShell sub-agent" Foreground="#AAB2BF" />
                                        <TextBlock x:Name="RuntimeStatusText" Text="QUEUED" Foreground="#F1C77A" />
                                    </StackPanel>
                                    <ScrollViewer x:Name="RuntimeScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="RuntimeOutputText" TextWrapping="NoWrap" FontFamily="Cascadia Mono, Consolas" FontSize="13" Foreground="#D5DAE2" IsTextSelectionEnabled="True" />
                                    </ScrollViewer>
                                    <TextBox x:Name="RuntimeInputText" Grid.Row="2" Margin="0,8,0,0" FontFamily="Cascadia Mono, Consolas" PlaceholderText="Runtime command and press Enter" KeyDown="RuntimeInputText_KeyDown" />
                                </Grid>
                            </Border>
                        </muxc:TabViewItem>
                        <muxc:TabViewItem Header="UI ✓">
                            <Border Background="#0A0B0D" Padding="16">
                                <TextBlock Text="UI session complete." Foreground="#AAB2BF" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </muxc:TabViewItem>
                        <muxc:TabViewItem Header="Tests !">
                            <Border Background="#0A0B0D" Padding="16">
                                <TextBlock Text="Tests require attention." Foreground="#F18A8A" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                        </muxc:TabViewItem>
                    </muxc:TabView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
