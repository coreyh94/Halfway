<Window x:Class="Halfway.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:muxc="using:Microsoft.UI.Xaml.Controls" xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives" Title="Halfway">
 <Grid Background="{ThemeResource AppBackgroundBrush}">
  <Grid.KeyboardAccelerators>
   <KeyboardAccelerator Key="Number1" Modifiers="Control" Invoked="FocusPrimary_Invoked"/>
   <KeyboardAccelerator Key="Number2" Modifiers="Control" Invoked="FocusSubAgent_Invoked"/>
   <KeyboardAccelerator Key="Tab" Modifiers="Control" Invoked="NextSubAgent_Invoked"/>
   <KeyboardAccelerator Key="Tab" Modifiers="Control,Shift" Invoked="PreviousSubAgent_Invoked"/>
   <KeyboardAccelerator Key="Up" Modifiers="Menu" Invoked="PreviousSidebarSession_Invoked"/>
   <KeyboardAccelerator Key="Down" Modifiers="Menu" Invoked="NextSidebarSession_Invoked"/>
   <KeyboardAccelerator Key="N" Modifiers="Control,Shift" Invoked="AddSubAgent_Invoked"/>
   <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="OpenTerminalSearch_Invoked"/>
   <KeyboardAccelerator Key="F3" Invoked="NextSearchMatch_Invoked"/>
   <KeyboardAccelerator Key="F3" Modifiers="Shift" Invoked="PreviousSearchMatch_Invoked"/>
  </Grid.KeyboardAccelerators>
  <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition Height="*"/></Grid.RowDefinitions>
  <Border Background="{ThemeResource TopBarBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"><Grid Padding="20,0"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
   <StackPanel VerticalAlignment="Center"><TextBlock Text="HALFWAY" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}"/><TextBlock Text="Codex workspace" FontSize="11" Foreground="{ThemeResource MutedTextBrush}"/></StackPanel>
   <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="20"><TextBlock x:Name="WorkspaceText" Foreground="{ThemeResource SecondaryTextBrush}"/><TextBlock x:Name="RepositoryText" Foreground="{ThemeResource MutedTextBrush}"/><TextBlock x:Name="BranchText" Foreground="{ThemeResource MutedTextBrush}"/><TextBlock Text="MODEL —" Foreground="{ThemeResource MutedTextBrush}"/></StackPanel>
   <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12"><TextBlock x:Name="RunningCountText" Foreground="{ThemeResource RunningBrush}" FontSize="11"/><TextBlock x:Name="WaitingCountText" Foreground="{ThemeResource WaitingBrush}" FontSize="11"/><TextBlock x:Name="CompletedCountText" Foreground="{ThemeResource CompletedBrush}" FontSize="11"/><TextBlock x:Name="ConnectionText" Foreground="{ThemeResource MutedTextBrush}" FontSize="11"/><Button Content="Export diagnostics" Click="ExportDiagnostics_Click"/></StackPanel>
  </Grid></Border>
  <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition x:Name="SidebarColumn" Width="236"/><ColumnDefinition Width="5"/><ColumnDefinition x:Name="PrimaryColumn" Width="*"/><ColumnDefinition Width="5"/><ColumnDefinition x:Name="SubAgentColumn" Width="420"/></Grid.ColumnDefinitions>
   <Border Background="{ThemeResource SidebarBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0" Padding="14,22"><ScrollViewer><StackPanel Spacing="8"><TextBlock Text="AGENT" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource MutedTextBrush}" Margin="8,0,0,6"/><StackPanel x:Name="PrimaryList" Spacing="4"/><Grid Margin="8,24,0,6"><TextBlock Text="SUB-AGENTS" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource MutedTextBrush}"/><Button Content="Add sub-agent" HorizontalAlignment="Right" Click="AddSubAgent_Click"/></Grid><StackPanel x:Name="SubAgentList" Spacing="4"/></StackPanel></ScrollViewer></Border>
   <primitives:Thumb Grid.Column="1" Background="{ThemeResource BorderBrush}" IsTabStop="False" DragDelta="SidebarSplitter_DragDelta" DoubleTapped="SidebarSplitter_DoubleTapped"/>
   <Border Grid.Column="2" Background="{ThemeResource MainBackgroundBrush}" Padding="18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock x:Name="MainSessionTitle" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource PrimaryTextBrush}" Margin="4,0,0,14"/><Grid x:Name="PrimaryTerminalHost" Grid.Row="1"/></Grid></Border>
   <primitives:Thumb Grid.Column="3" Background="{ThemeResource BorderBrush}" IsTabStop="False" DragDelta="SubAgentSplitter_DragDelta" DoubleTapped="SubAgentSplitter_DoubleTapped"/>
   <Border Grid.Column="4" Background="{ThemeResource SubAgentBackgroundBrush}" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1,0,0,0" Padding="14,18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="SUB-AGENTS" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource MutedTextBrush}" Margin="4,0,0,12"/><muxc:TabView x:Name="SubAgentTabs" Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="Equal" Background="{ThemeResource TabBackgroundBrush}" SelectionChanged="SubAgentTabs_SelectionChanged"/></Grid></Border>
  </Grid>
 </Grid>
</Window>
