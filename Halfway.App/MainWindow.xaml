<Window x:Class="Halfway.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:muxc="using:Microsoft.UI.Xaml.Controls" Title="Halfway">
 <Grid Background="#101114"><Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition Height="*"/></Grid.RowDefinitions>
  <Border Background="#17191E" BorderBrush="#2C3039" BorderThickness="0,0,0,1"><Grid Padding="20,0"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
   <StackPanel VerticalAlignment="Center"><TextBlock Text="HALFWAY" FontSize="15" FontWeight="SemiBold" Foreground="#F3F4F6"/><TextBlock Text="Codex workspace" FontSize="11" Foreground="#8D96A5"/></StackPanel>
   <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="20"><TextBlock x:Name="WorkspaceText" Foreground="#C9D1DC"/><TextBlock x:Name="RepositoryText" Foreground="#8D96A5"/><TextBlock x:Name="BranchText" Foreground="#8D96A5"/><TextBlock Text="MODEL —" Foreground="#8D96A5"/></StackPanel>
   <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12"><TextBlock x:Name="RunningCountText" Foreground="#7DD3A8" FontSize="11"/><TextBlock x:Name="WaitingCountText" Foreground="#F1C77A" FontSize="11"/><TextBlock x:Name="CompletedCountText" Foreground="#9DA7FF" FontSize="11"/><TextBlock x:Name="ConnectionText" Foreground="#8D96A5" FontSize="11"/></StackPanel>
  </Grid></Border>
  <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="236"/><ColumnDefinition Width="*"/><ColumnDefinition Width="420"/></Grid.ColumnDefinitions>
   <Border Background="#15171B" BorderBrush="#2C3039" BorderThickness="0,0,1,0" Padding="14,22"><ScrollViewer><StackPanel Spacing="8"><TextBlock Text="AGENT" FontSize="11" FontWeight="SemiBold" Foreground="#7B8492" Margin="8,0,0,6"/><StackPanel x:Name="PrimaryList" Spacing="4"/><Grid Margin="8,24,0,6"><TextBlock Text="SUB-AGENTS" FontSize="11" FontWeight="SemiBold" Foreground="#7B8492"/><Button Content="Add sub-agent" HorizontalAlignment="Right" Click="AddSubAgent_Click"/></Grid><StackPanel x:Name="SubAgentList" Spacing="4"/></StackPanel></ScrollViewer></Border>
   <Border Grid.Column="1" Background="#0F1013" Padding="18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock x:Name="MainSessionTitle" FontSize="16" FontWeight="SemiBold" Foreground="#F3F4F6" Margin="4,0,0,14"/><Grid x:Name="PrimaryTerminalHost" Grid.Row="1"/></Grid></Border>
   <Border Grid.Column="2" Background="#15171B" BorderBrush="#2C3039" BorderThickness="1,0,0,0" Padding="14,18"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="SUB-AGENTS" FontSize="11" FontWeight="SemiBold" Foreground="#7B8492" Margin="4,0,0,12"/><muxc:TabView x:Name="SubAgentTabs" Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="Equal" Background="#111318" SelectionChanged="SubAgentTabs_SelectionChanged"/></Grid></Border>
  </Grid>
 </Grid>
</Window>
